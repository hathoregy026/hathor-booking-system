# PostgreSQL — Supabase transaction pooler (port 6543) for app runtime
# URL-encode @ in password as %40. Include pgbouncer=true for Prisma.
# Pool params (also overridable via env below):
#   connection_limit=5  pool_timeout=15  connect_timeout=10
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=no-verify&connection_limit=5&pool_timeout=15&connect_timeout=10"

# Optional pool overrides (lib/database-config.ts + lib/pg-pool.ts)
# DATABASE_CONNECTION_LIMIT=5
# DATABASE_POOL_TIMEOUT=15
# DATABASE_CONNECT_TIMEOUT=10
# DATABASE_IDLE_TIMEOUT_MS=10000

# Session pooler (port 5432) — only if you run a single server instance; limited to ~15 connections
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres?sslmode=no-verify"

# Direct connection for Prisma CLI migrations (db.PROJECT_REF.supabase.co:5432).
# DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

ADMIN_PASSWORD="your-admin-password"

# Required for POST /api/cron/cleanup — use a long random string (e.g. openssl rand -hex 32)
# Send as: Authorization: Bearer <CRON_SECRET>
CRON_SECRET="your-cron-secret"

# Optional — signs booking hold tokens (falls back to CRON_SECRET, then ADMIN_PASSWORD)
# BOOKING_HOLD_SECRET="your-booking-hold-secret"

# Resend (https://resend.com) — transactional email
RESEND_API_KEY="re_xxxxxxxx"
# Verified sender in Resend (use onboarding@resend.dev for testing)
RESEND_FROM_EMAIL="Hathor Dahabiya <onboarding@resend.dev>"
# Receives new-booking admin alerts
ADMIN_EMAIL="you@example.com"

# Optional — canonical public site URL (used for email image links and uploads)
NEXT_PUBLIC_SITE_URL="https://hathor-booking-system.vercel.app"

# Supabase (Project Settings → API)
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
# Required for server-side image uploads in production (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# Optional — used only if service role key is not set
SUPABASE_ANON_KEY="your-anon-key"
