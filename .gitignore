# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# locally uploaded admin/site images (when Supabase is not configured)
/public/uploads/**
!/public/uploads/.gitkeep

# large media — synced locally; host on CDN/Vercel Blob for production
/assets/*.mp4
/assets/TEMPORARY IMAGES FOR HATHOR/
/public/videos/*.mp4
/public/media/hathor/videos/hero-reel.mp4

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# frozen local scroll reveal reference (never commit)
/_local/scroll-reveal-effect/

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
