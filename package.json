{
  "name": "hathor-booking-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/sync-email-assets.mjs && prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "seed:hathor": "node scripts/seed-hathor-data.mjs",
    "seed:content": "node scripts/seed-raw-content.mjs",
    "seed:email-templates": "node scripts/seed-email-templates.mjs",
    "seed:email-template-urls": "node scripts/seed-email-template-urls.mjs",
    "optimize:email-images": "node --env-file=.env scripts/optimize-email-bucket-images.mjs",
    "backfill:email-images": "node scripts/backfill-email-template-images.mjs",
    "email:dev": "node scripts/sync-email-assets.mjs && email dev --dir emails --port 3005",
    "validate:availability": "tsx scripts/validate-calendar-availability.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.9",
    "@supabase/supabase-js": "^2.108.2",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.42.0",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-email": "^6.6.4",
    "resend": "^6.14.0",
    "sharp": "^0.35.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@react-email/ui": "^6.6.4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
